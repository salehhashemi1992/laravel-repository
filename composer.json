{
    "name": "salehhashemi/laravel-repository",
    "description": "Implementing the repository pattern for Laravel projects.",
    "license": "MIT",
    "authors": [
        {
            "name": "Saleh Hashemi",
            "email": "salpars2004@gmail.com",
            "role": "Developer"
        }
    ],
    "homepage": "https://github.com/salehhashemi1992/laravel-repository",
    "keywords": [
        "Laravel",
        "repository pattern",
        "php",
        "design patterns",
        "laravel package",
        "eloquent",
        "database abstraction"
    ],
    "type": "library",
    "require": {
        "php": "^8.2",
        "laravel/framework": "12.*|13.*"
    },
    "require-dev": {
        "laravel/pint": "^1.26.0",
        "orchestra/testbench": "^10.0|^11.0",
        "phpunit/phpunit": "^10.0|^11.0",
        "phpstan/phpstan": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "Salehhashemi\\Repository\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Salehhashemi\\Repository\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "test-coverage": "vendor/bin/phpunit --coverage-html coverage",
        "format": "vendor/bin/pint",
        "analyse": "vendor/bin/phpstan analyse"
    },
    "config": {
        "sort-packages": true
    },
    "extra": {
        "laravel": {
            "providers": [
                "Salehhashemi\\Repository\\RepositoryServiceProvider"
            ]
        }
    }
}
